# Spotify playlist IDs for archive_top50.py
#
# SOURCE_PLAYLIST_ID: 取得元プレイリスト (例: Spotify 公式 "Top 50 - Global")
# DEST_PLAYLIST_ID:   追加先プレイリスト (自分のアカウントで作成して ID を貼る)
#
# Spotify アプリでプレイリストを右クリック → "シェア" → "Spotify URI をコピー"
# 例: spotify:playlist:5FN6Ego7eLX6zHuCMovIR2 → ID 部分は 5FN6Ego7eLX6zHuCMovIR2

SOURCE_PLAYLIST_ID=5FN6Ego7eLX6zHuCMovIR2
DEST_PLAYLIST_ID=
